{
  "version": 2,
  "projects": [
    {
      "name": "frontend",
      "rootDirectory": "frontend",
      "buildCommand": "npm run build",
      "outputDirectory": "dist",
      "framework": "vite",
      "env": [
        "VITE_SUPABASE_URL",
        "VITE_SUPABASE_ANON_KEY",
        "VITE_API_URL"
      ]
    },
    {
      "name": "backend",
      "rootDirectory": "backend",
      "buildCommand": "npm run build",
      "outputDirectory": "dist",
      "framework": "nodejs",
      "env": [
        "SUPABASE_URL",
        "SUPABASE_ANON_KEY",
        "SUPABASE_SERVICE_ROLE_KEY",
        "JWT_SECRET",
        "JWT_EXPIRATION",
        "NODE_ENV",
        "FRONTEND_URL"
      ]
    }
  ]
}
